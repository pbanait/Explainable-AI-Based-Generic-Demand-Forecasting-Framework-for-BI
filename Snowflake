USE DATABASE DB_BI_RAW;
USE SCHEMA GENERAL_USE;

use warehouse compute_wh;
truncate table SALES_ORDER;
CREATE OR REPLACE TABLE SALES_ORDER (
    ORDER_ID        VARCHAR,
    CUSTOMER_ID     VARCHAR,
    CUSTOMER_TYPE   VARCHAR,
    PRODUCT         VARCHAR,
    CATEGORY        VARCHAR,
    UNIT_PRICE      DOUBLE,
    QUANTITY        NUMBER(38,0),
    DISCOUNT        DOUBLE,
    TOTAL_PRICE     DOUBLE,
    REGION          VARCHAR,
    ORDER_DATE      DATE
);

CREATE OR REPLACE FILE FORMAT SALES_ORDER_FILE
  TYPE = 'CSV'
  FIELD_OPTIONALLY_ENCLOSED_BY = '"'
  SKIP_HEADER = 1;


  CREATE OR REPLACE STAGE SALES_ORDER_STAGE
  URL='azure://biproject.blob.core.windows.net/files'
  CREDENTIALS = (AZURE_SAS_TOKEN='sp=racwdli&st=2026-03-17T14:39:41Z&se=2026-06-19T22:54:41Z&spr=https&sv=2024-11-04&sr=c&sig=LW09WFZvzpPeUZC%2BdjVG4UlYy3%2BJW3VQy2Lr9BB99kk%3D')
  FILE_FORMAT = SALES_ORDER_FILE;

  LIST @SALES_ORDER_STAGE;


CREATE OR REPLACE TASK LOAD_SALES_ORDER_TASK
  WAREHOUSE = COMPUTE_WH
  SCHEDULE = '5 MINUTE'
AS
COPY INTO SALES_ORDER
FROM @SALES_ORDER_STAGE
FILE_FORMAT = (FORMAT_NAME = SALES_ORDER_FILE)
ON_ERROR = 'CONTINUE';


ALTER TASK LOAD_SALES_ORDER_TASK SUSPEND;


ALTER TASK LOAD_SALES_ORDER_TASK RESUME;

EXECUTE TASK LOAD_SALES_ORDER_TASK;

select * from sales_order;

show tasks;
